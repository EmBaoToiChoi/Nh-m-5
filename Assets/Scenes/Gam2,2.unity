  m_Script: {fileID: 11500000, guid: 7e571fa2a7c14d04a84ad3a3b699afdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  panel: {fileID: 1557743336}
  storyText: {fileID: 505200077}
  btnNext: {fileID: 421060160}
  btnSkip: {fileID: 604947405}
  typingSpeed: 0.05
  storyIndex: 6
  storyLines:
  - "Ph\xF2ng S\u1ED1 6 \u2013 N\u01A1i T\u1ED9i L\u1ED7i Ng\u1EF1 Tr\u1ECB\nSau
    khi v\u01B0\u1EE3t qua nh\u1EEFng t\u1EA7ng ng\u1EE5c \u0111\u1EA7u ti\xEAn,
    n\u01A1i ch\u1EC9 th\u1EED th\xE1ch th\u1EC3 x\xE1c, b\u1EA1n b\u01B0\u1EDBc
    v\xE0o Ph\xF2ng S\u1ED1 6 \u2013 n\u01A1i b\xF3ng t\u1ED1i \u0111\xE3 \u0103n
    m\xF2n c\u1EA3 linh h\u1ED3n. M\u1ECDi v\u1EBFt m\xE1u \u1EDF \u0111\xE2y \u0111\u1EC1u
    \u0111\xE3 kh\xF4 t\u1EEB h\xE0ng th\u1EBF k\u1EF7, nh\u01B0ng ti\u1EBFng than
    kh\xF3c, l\u1EDDi nguy\u1EC1n v\xE0 m\xF9i tro ch\xE1y v\u1EABn ch\u01B0a h\u1EC1
    tan bi\u1EBFn. \u0110\xE2y kh\xF4ng ch\u1EC9 l\xE0 n\u01A1i b\u1EA1n chi\u1EBFn
    \u0111\u1EA5u\u2026 m\xE0 l\xE0 n\u01A1i b\u1EA1n b\u1ECB nh\xECn th\u1EA5u."
  - "1. QU\u1EF6 \u2013 H\xECnh H\xE0i C\u1EE7a S\u1EF1 Tuy\u1EC7t V\u1ECDng\nT\u1EEB
    trong nh\u1EEFng v\u1EBFt n\u1EE9t s\xE2u th\u1EB3m, Qu\u1EF7 tr\u1ED7i d\u1EADy
    \u2013 kh\xF4ng ph\u1EA3i sinh v\u1EADt s\u1ED1ng, m\xE0 l\xE0 hi\u1EC7n th\xE2n
    c\u1EE7a s\u1EF1 th\xF9 h\u1EADn, ghen gh\xE9t v\xE0 \u0111au kh\u1ED5. V\u1EDBi
    \u0111\xF4i s\u1EEBng ch\xE1y \u0111\u1ECF v\xE0 m\xF3ng vu\u1ED1t x\xE9 r\xE1ch
    linh h\u1ED3n, n\xF3 th\xEC th\u1EA7m v\xE0o \u0111\u1EA7u b\u1EA1n nh\u1EEFng
    l\u1EDDi d\u1ED1i tr\xE1 khi\u1EBFn b\u1EA1n nghi ng\u1EDD ch\xEDnh m\xECnh.
    M\u1ED7i khi b\u1EA1n g\u1EE5c ng\xE3, n\xF3 m\u1EA1nh h\u01A1n."
  - "2. D\u01A0I L\u1EECA \u2013 B\xF3ng T\u1ED1i C\xF3 C\xE1nh\nTr\xEAn tr\u1EA7n
    hang, D\u01A1i L\u1EEDa treo ng\u01B0\u1EE3c l\u1EB7ng l\u1EBD, ch\u1EDD \u0111\u1EE3i
    con m\u1ED3i s\u01A1 h\u1EDF. Ch\xFAng kh\xF4ng t\u1EA5n c\xF4ng v\xEC \u0111\xF3i
    \u2013 m\xE0 v\xEC b\u1EA3n ch\u1EA5t \u0111i\xEAn lo\u1EA1n. Khi x\xF2e c\xE1nh,
    l\u1EEDa b\xF9ng l\xEAn t\u1EEB t\u1EEBng c\xFA qu\u1EA1t, \u0111\u1ED1t ch\xE1y
    m\u1ECDi th\u1EE9 d\u01B0\u1EDBi ch\xE2n. \u0110\u1EEBng d\u1EEBng l\u1EA1i\u2026
    v\xEC ch\u1EC9 c\u1EA7n m\u1ED9t gi\xE2y ch\u1EADm tr\u1EC5, l\xE0 c\xE1i ch\u1EBFt
    \u0111\u1EBFn t\u1EEB ph\xEDa tr\xEAn."
  - "3. PH\xD9 TH\u1EE6Y \u2013 K\u1EBB \u0110i\u1EC1u Khi\u1EC3n L\u1EDDi Nguy\u1EC1n\n\u1EA8n
    m\xECnh sau nh\u1EEFng c\u1ED9t \u0111\xE1 g\xE3y \u0111\u1ED5 l\xE0 Ph\xF9 Th\u1EE7y
    \u2013 m\u1ED9t k\u1EBB t\u1EEBng l\xE0 h\u1ECDc gi\u1EA3 cao qu\xFD, nay b\u1ECB
    tha h\xF3a b\u1EDFi c\xE1m d\u1ED7 s\u1EE9c m\u1EA1nh. C\xF4 ta th\xEC th\u1EA7m
    nh\u1EEFng c\xE2u th\u1EA7n ch\xFA c\u1ED5 x\u01B0a, tri\u1EC7u h\u1ED3i l\u1EEDa,
    b\xF3ng t\u1ED1i v\xE0 \u1EA3o gi\xE1c. \u0110\u1EEBng tin v\xE0o m\u1EAFt m\xECnh,
    v\xEC kh\xF4ng ph\u1EA3i m\u1ECDi th\u1EE9 b\u1EA1n th\u1EA5y \u0111\u1EC1u th\u1EADt.
    K\u1EBB \u0111\u1ECBch c\xF3 th\u1EC3 l\xE0 c\xE1i b\xF3ng ph\xEDa sau\u2026
    ho\u1EB7c ch\xEDnh b\u1EA3n th\xE2n b\u1EA1n."
  - "4. NG\u01AF\u1EDCI \u0110\xC1 \u2013 V\u1EC7 Th\u1EA7n L\u1ED7i Th\u1EDDi\nCu\u1ED1i
    c\xF9ng, b\u1EA1n ph\u1EA3i \u0111\u1ED1i m\u1EB7t v\u1EDBi Ng\u01B0\u1EDDi \u0110\xE1
    \u2013 m\u1ED9t t\u1EA1o v\u1EADt c\u1ED5 x\u01B0a \u0111\u01B0\u1EE3c t\u1EA1c
    t\u1EEB dung nham \u0111\xF4ng c\u1EE9ng. N\xF3 kh\xF4ng c\xF3 c\u1EA3m x\xFAc,
    kh\xF4ng bi\u1EBFt \u0111au, ch\u1EC9 bi\u1EBFt l\xE0m theo m\u1EC7nh l\u1EC7nh
    \u0111\xE3 b\u1ECB l\xE3ng qu\xEAn t\u1EEB ng\xE0n n\u0103m. M\u1ED7i c\xFA \u0111\xE1nh
    c\u1EE7a n\xF3 khi\u1EBFn \u0111\u1EA5t n\u1EE9t, t\u01B0\u1EDDng \u0111\u1ED5
    v\xE0 t\xE2m tr\xED b\u1EA1n rung chuy\u1EC3n. \u0110\u1EC3 v\u01B0\u1EE3t qua,
    b\u1EA1n kh\xF4ng th\u1EC3 ch\u1EC9 m\u1EA1nh \u2013 b\u1EA1n ph\u1EA3i th\xF4ng
    minh, ki\xEAn nh\u1EABn, v\xE0 bi\u1EBFt khi n\xE0o n\xEAn n\xE9, khi n\xE0o
    n\xEAn t\u1EA5n c\xF4ng."
  - "Ph\xF2ng S\u1ED1 6 l\xE0 l\u1EDDi nh\u1EAFc r\u1EB1ng b\xF3ng t\u1ED1i kh\xF4ng
    ch\u1EC9 \u0111\u1EBFn t\u1EEB b\xEAn ngo\xE0i\u2026 m\xE0 c\xF2n s\u1ED1ng trong
    ch\xEDnh b\u1EA1n.\nLi\u1EC7u b\u1EA1n s\u1EBD gi\u1EEF \u0111\u01B0\u1EE3c l\xFD
    tr\xED gi\u1EEFa m\xEA cung \u1EA3o \u1EA3nh n\xE0y, hay s\u1EBD tr\u1EDF th\xE0nh
    m\u1ED9t ph\u1EA7n c\u1EE7a n\xF3 \u2013 m\xE3i m\xE3i?"
